{
    "name": "Chrome Remote Desktop",
    "id": "aarontburn.Chrome_Remote_Desktop",
    "author": "aarontburn",
    "version": "1.0.0",
    "description": "https://remotedesktop.google.com as a Nexus module.",
    "platforms": [
        "win32",
        "linux",
        "darwin"
    ],
    "git-latest": {
        "git-username": "aarontburn",
        "git-repo-name": "nexus-chrome-remote-desktop"
    },
    "link": "https://github.com/aarontburn/nexus-chrome-remote-desktop",
    "build": {
        "build-version": 2,
        "excluded": [
            "electron.ts"
        ],
        "included": [],
        "process": "./process/main.js",
        "replace": [
            {
                "from": "{EXPORTED_MODULE_ID}",
                "to": "%id%",
                "at": [
                    "./process/main.ts"
                ]
            },
            {
                "from": "{EXPORTED_MODULE_NAME}",
                "to": "%name%",
                "at": [
                    "./process/main.ts"
                ]
            }
        ]
    }
}